# Postgres connection string (Supabase or otherwise) — wired up later
DATABASE_URL="postgresql://user:password@host:5432/yaara?schema=public"

# JWT
JWT_SECRET="change-me-to-a-long-random-string"
JWT_EXPIRES_IN="8h"
REFRESH_TOKEN_SECRET="change-me-to-a-different-long-random-string"

# Server
PORT=4000
CORS_ORIGINS="http://localhost:3000"

# Node env
NODE_ENV=development
